{
  // oh-my-openagent configuration
  // Based on Chinese LLM research (2026-04-05)

  "agents": {
    "sisyphus": {
      "model": "meituan/claude-opus-4-6",
      "temperature": 0.3,
      "max_tokens": 8192
    },
    "hephaestus": {
      "model": "meituan/claude-opus-4-6",
      "temperature": 0.3,
      "max_tokens": 8192
    },
    "prometheus": {
      "model": "meituan/claude-opus-4-6",
      "temperature": 0.5,
      "max_tokens": 8192
    },
    "oracle": {
      "model": "meituan/claude-opus-4-6",
      "temperature": 0.3,
      "max_tokens": 8192
    },
    "metis": {
      // Pre-planning consultant: identifies hidden intent, ambiguities, AI failure points
      // 0.5 matches prometheus (planning) — needs some divergent thinking to surface edge cases
      "model": "meituan/claude-opus-4-6",
      "temperature": 0.5,
      "max_tokens": 8192
    },
    "librarian": {
      // Docs and code search - uses MiniMax for speed
      "model": "meituan/claude-sonnet-4-6",
      "temperature": 0.3,
      "max_tokens": 8192
    },
    "explore": {
      // Fast codebase grep - uses MiniMax for speed
      "model": "meituan/claude-sonnet-4-6",
      "temperature": 0.3,
      "max_tokens": 8192
    },
    "sisyphus-junior": {
      "model": "meituan/claude-sonnet-4-6",
      "temperature": 0.3,
      "max_tokens": 8192
    }
  },

  // Category to model routing
  // Maps task type to default agent
  "category_default_model": {
    "deep": "meituan/claude-opus-4-6",
    "quick": "meituan/claude-sonnet-4-6",
    "ultrabrain": "meituan/claude-opus-4-6",
    "visual-engineering": "meituan/claude-sonnet-4-6",
    "business-logic": "meituan/claude-opus-4-6",
    "reasoning": "meituan/claude-opus-4-6",
    "creative": "meituan/claude-opus-4-6"
  },

  // Model capabilities reference (from research)
  "model_capabilities": {
    "kimi-k2.5": {
      "context": 256000,
      "strengths": ["coding", "math", "reasoning", "tool_use"],
      "benchmarks": {
        "LiveCodeBench": "53.7%",
        "SWE-bench-Agentic": "65.8%",
        "MATH-500": "97.4%"
      }
    },
    "MiniMax-M2.7": {
      "context": 128000,
      "strengths": ["agent_rl", "coding", "self_evolution", "speed"],
      "benchmarks": {
        "SWE-Pro": "56.22%"
      }
    },
    "GLM-5.1": {
      "context": 128000,
      "strengths": ["agentic", "research", "deep_thinking"]
    },
    "qwen3.5-plus": {
      "context": 262000,
      "strengths": ["long_context", "multilingual", "unified_thinking"]
    }
  },

  // MCP servers - built-in
  "mcp_servers": {
    "enabled": true,
    "servers": ["websearch", "context7", "grep_app"]
  },

  // Hooks - can disable specific hooks
  "disabled_hooks": [],

  // ultrawork settings
  "ultrawork": {
    "concurrency_limit": 5,
    "auto_retry": true,
    "max_retries": 3
  },

  // Hash-anchored edit settings
  "hashline": {
    "enabled": true,
    "validate_on_edit": true
  }
}
